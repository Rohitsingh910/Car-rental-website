    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@types/socket.io": "^3.0.1",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.5",
    "razorpay": "^2.8.6",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/morgan": "^1.9.4",
    "@types/node": "^18.16.1",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.4",
    "vitest": "^4.1.10"
