{
  "name": "desirent-backend",
  "version": "1.0.0",
  "description": "Full-stack Backend for DesiRent Car Rental Website",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
